DISCORD_TOKEN=your_discord_bot_token
TRACKER_GG_API_KEY=your_tracker_gg_api_key

# Discord OAuth for site login (Discord Developer Portal → Your App → OAuth2 → add redirect)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# SESSION_SECRET=random_string_for_signing_cookies
# INITIAL_MANAGEMENT_DISCORD_IDS=discord_id1,discord_id2  # First login sets management role

# Ballchasing (optional) - Fallback when local parser fails. https://ballchasing.com/upload
# BALLCHASING_API_TOKEN=

# Supabase - Get from: Dashboard → Project Settings → Database → Connection string (URI)
# Use "Transaction" or "Session" pooler for the connection string
SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
